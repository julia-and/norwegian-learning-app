# URL of the Scaleway Serverless Function that proxies Claude API requests.
# Set this before running `npm run build` so it gets baked into the static export.
# Get this URL after deploying with: scw function function get <FUNCTION_ID>
NEXT_PUBLIC_CORRECTION_API_URL=norsktrackerdanylnqo-correct.functions.fnc.fr-par.scw.cloud

# URL of the Scaleway Serverless Function for the conversation partner feature.
NEXT_PUBLIC_CONVERSATION_API_URL=norsktrackerdanylnqo-converse.functions.fnc.fr-par.scw.cloud

# URL of the Scaleway Serverless Function for the reading feed generator.
NEXT_PUBLIC_FEED_API_URL=norsktrackerdanylnqo-generate-feed.functions.fnc.fr-par.scw.cloud

# Shared secret sent as `x-app-secret` on every proxy call.
# Anti-abuse only — visible in the shipped JS bundle. Stops bots/crawlers
# from running up Anthropic spend if someone discovers the function URLs.
# Generate with: openssl rand -hex 32
# Must match the APP_SHARED_SECRET env var configured on each Scaleway function.
NEXT_PUBLIC_APP_SHARED_SECRET=

# YouTube Data API v3 key (used by the resource indexer function).
# Create one at https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in the API library first.
YOUTUBE_API_KEY=

# ────────────────────────────────────────────────────────────────────────
# Server-side env vars (set on each Scaleway function, NOT in this file):
#
#   ANTHROPIC_API_KEY        — required, secret
#   APP_SHARED_SECRET        — required, must match NEXT_PUBLIC_APP_SHARED_SECRET
#   ALLOWED_ORIGINS          — comma-separated allowlist of browser origins,
#                              e.g. "https://lang-learning-tracking-app.s3-website.fr-par.scw.cloud"
#                              (Use "*" only for testing; an explicit list is
#                              the production default.)
#   ANTHROPIC_API_VERSION    — optional, defaults to "2023-06-01"
# ────────────────────────────────────────────────────────────────────────
