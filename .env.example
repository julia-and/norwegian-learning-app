# URL of the Scaleway Serverless Function that proxies Claude API requests.
# Set this before running `npm run build` so it gets baked into the static export.
# Get this URL after deploying with: scw function function get <FUNCTION_ID>
NEXT_PUBLIC_CORRECTION_API_URL=norsktrackerdanylnqo-correct.functions.fnc.fr-par.scw.cloud

# URL of the Scaleway Serverless Function for the conversation partner feature.
NEXT_PUBLIC_CONVERSATION_API_URL=

# YouTube Data API v3 key (used by the resource indexer function).
# Create one at https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in the API library first.
YOUTUBE_API_KEY=
